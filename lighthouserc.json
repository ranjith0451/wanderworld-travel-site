{
  "ci": {
    "collect": {
      "staticDistDir": "./",
      "url": [
        "http://localhost/index.html"
      ]
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 0.80 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}